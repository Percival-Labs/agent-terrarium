# Claw3D — Percival Labs Fork
# Security-hardened for production agent visualization

# Gateway connection (runtime, no rebuild needed)
CLAW3D_GATEWAY_URL=ws://localhost:18789
# CLAW3D_GATEWAY_TOKEN=

# Build-time gateway URL (requires npm run build after changes)
NEXT_PUBLIC_GATEWAY_URL=ws://localhost:18789

# Required for production: access token for Studio
# STUDIO_ACCESS_TOKEN=

# Required for production: restrict WebSocket proxy to trusted upstreams
# Comma-separated hostnames. Empty = allow all (dev only).
# UPSTREAM_ALLOWLIST=gateway.percival-labs.ai,localhost

# App server
# PORT=3000
# HOST=127.0.0.1

# Debug UI
DEBUG=true

# SSH (not needed for our integration)
# OPENCLAW_GATEWAY_SSH_TARGET=
# OPENCLAW_GATEWAY_SSH_USER=

# Voice (disabled in this fork)
# ELEVENLABS_API_KEY=
